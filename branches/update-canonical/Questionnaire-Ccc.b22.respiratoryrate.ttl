       ] ;
       fhir:value [
         a fhir:Expression ;
         fhir:language [ fhir:v "text/fhirpath" ] ;
         fhir:expression [ fhir:v "%resource.repeat(item).where(linkId='Fast Breathing profile').answer.first().empty() and (%resource.repeat(item).where(linkId='AgeInMonths').answer.first().value >= 2 or %resource.repeat(item).where(linkId='second').repeat(item).where(linkId='Ccc.B22.DE04').answer.first().exists() or  %resource.repeat(item).where(linkId='second').repeat(item).where(linkId='Ccc.B22.DE05').answer.first().exists() or  %resource.repeat(item).where(linkId='Ccc.B22.DE01').answer.first().value < 60 '{Breaths}/min')" ]
