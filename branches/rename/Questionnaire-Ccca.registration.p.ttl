       fhir:language [ fhir:v "text/fhirpath" ] ;
       fhir:expression [ fhir:v "iif( %resource.repeat(item).where(linkId='Ccc.A.DE14.d').answer.first().exists()  ,%resource.repeat(item).where(linkId='Ccc.A.DE14.d').answer.first().value , 0 days)" ]
