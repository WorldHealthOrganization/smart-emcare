         ] ;
         fhir:value [
           a fhir:Expression ;
           fhir:language [ fhir:v "text/fhirpath" ] ;
           fhir:expression [ fhir:v "%resource.repeat(item).where(linkId='Oxygen_Saturation').repeat(item).where(linkId='Ccc.B10S2.DE07').answer.first().exists() and %resource.repeat(item).where(linkId='Oxygen_Saturation').repeat(item).where(linkId='Ccc.B10S2.DE07').answer.first().value< 90 '%'" ]
         ]
       ] ) ;
       fhir:linkId [ fhir:v "Ccc.B10S2.DE08" ] ;
       fhir:text [ fhir:v "Oxygen Saturation < 90 %" ] ;
       fhir:type [ fhir:v "display" ] ;
       fhir:required [ fhir:v false ] ;
