       fhir:linkId [ fhir:v "Ccc.B17S1.DE01-help" ] ;
       fhir:text [ fhir:v "Look to see if the child has a throat problem. <br />\n- Red (congested) throat indicates inflammation and may be sign of infection<br />\n- Exudate may be seen as white / yellow mucus on the tonsils or throat<br />\n- A membrane is a thick grey coating on the throat is a sign of diptheria, requiring urgent referral" ] ;
       fhir:type [ fhir:v "display" ]
     ] )
