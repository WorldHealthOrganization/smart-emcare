     fhir:Narrative.status [ fhir:value "generated" ];
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><ul><li>Include these codes as defined in <code>https://fhir.dk.swisstph-mis.ch/matchbox/fhir/CodeSystem/codesystem-emcare-custom-codes</code><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td></tr><tr><td>EmCare.B14S2.DE19</td><td>Skin Lesions ≥ 4 cm</td></tr><tr><td>EmCare.B14S2.DE20</td><td>Red Skin Streaks</td></tr><tr><td>EmCare.B14S2.DE21</td><td>Tender Nodes (Nodules) under the skin</td></tr><tr><td>EmCare.B14S2.DE22</td><td>Skin Infection extends to Muscle</td></tr><tr><td>EmCare.B14S2.DE23</td><td>Molluscum Contagiosum - Skin coloured pearly white papules with central umbilication. Most commonly seen on face and trunk in children.</td></tr><tr><td>EmCare.B14S2.DE24</td><td>Warts - Papules or nodules with a rough (Verrucous) surface</td></tr><tr><td>EmCare.B14S2.DE25</td><td>Seborrhea - Greasy scales and redness on central face and body folds</td></tr><tr><td>EmCare.B14S2.DE26</td><td>Fixed Drug Reactions - Generalised red, wide spread with small bumps or blisters; or one or more dark skin areas</td></tr><tr><td>EmCare.B14S2.DE27</td><td>Eczema - Wet oozing sores or excoriated, thick patches</td></tr><tr><td>EmCare.B14S2.DE28</td><td>Steven Johnson Syndrome - Severe reaction due to cotrimoxazole or NVP involving the skin as well as the eyes and the mouth.  Might cause difficulty in breathing</td></tr></table></li></ul></div>"
  ];
