     fhir:type [ fhir:v "group" ] ;
     fhir:required [ fhir:v false ] ;
     fhir:repeats [ fhir:v false ] ;
     fhir:item ( [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/StructureDefinition/questionnaire-unit"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/StructureDefinition/questionnaire-unit>
         ] ;
         fhir:value [
           a fhir:Coding ;
           fhir:system [
             fhir:v "http://unitsofmeasure.org"^^xsd:anyURI ;
