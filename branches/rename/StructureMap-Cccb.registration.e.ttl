  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><pre>map \"https://smart.who.int/ccc/StructureMap/Cccb.registration.e\" = \"Cccb.registration.e\"#xD;\n#xD;\n#xD;\nuses \"http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaireresponse\" alias 'questionnaireResponse' as source#xD;\nuses \"http://hl7.org/fhir/StructureDefinition/Bundle\" alias 'Bundle' as target#xD;\nuses \"https://smart.who.int/ccc/StructureDefinition/encounter\" alias 'Encounter' as target#xD;\nuses \"https://smart.who.int/ccc/StructureDefinition/observation\" alias 'Observation' as target#xD;\nuses \"https://smart.who.int/ccc/StructureDefinition/Cccencounter\" alias 'Ccc Encounter' as produced#xD;\nuses \"https://smart.who.int/ccc/StructureDefinition/Cccobservation\" alias 'Ccc Observation' as produced#xD;\n#xD;\ngroup bundletrans(source src : questionnaireResponse, target bundle : Bundle) {#xD;\n  src -&gt; bundle.id = uuid() \"id\";#xD;\n  src -&gt; bundle.type = 'batch' \"type\";#xD;\n  src -&gt; bundle.entry as entry then {#xD;\n    src.encounter as encounter then {#xD;\n      encounter.id as idval -&gt;  entry.request as request,  request.method = 'PUT',  request.url = append('/Encounter/', idval) \"f7ed42d5\";#xD;\n    } \"49f4ed45\";#xD;\n    src -&gt; entry.resource = create('Encounter') as tgt then {#xD;\n      src -&gt; tgt then Cccencounter(src, tgt) \"fd415ba8\";#xD;\n      src.subject as sub -&gt; tgt.subject = sub \"23252e10\";#xD;\n    } \"8f0160c6\";#xD;\n  } \"put-Cccencounter\";#xD;\n  src.item first as item where (linkId = 'Ccc.B3.DE05') and answer.exists() then {#xD;\n    src -&gt; bundle.entry as entry then {#xD;\n      src -&gt;  entry.request as request,  request.method = 'POST',  uuid() as uuid,  request.url = append('/Observation/', uuid) \"b50ac4c5\";#xD;\n      src -&gt; entry.resource = create('Observation') as tgt then {#xD;\n        src -&gt; tgt then CccobservationCccb3de05(src, tgt) \"918130f9\";#xD;\n      } \"172606cb\";#xD;\n    } \"a322e7db\";#xD;\n  } \"1af195c5\";#xD;\n}#xD;\n#xD;\ngroup Cccencounter(source src : questionnaireResponse, target tgt : Encounter) {#xD;\n  src.item first as item where (linkId = 'Ccc.B3.DE01') and answer.exists() then {#xD;\n    item.answer first as a then {#xD;\n      a.value as val -&gt;  tgt.reasonCode = create('CodeableConcept') as CC,  CC.text = 'new consultation',  CC.coding = val \"aCccb3de01\";#xD;\n    } \"aCccb3de01\";#xD;\n  } \"5ea28a7f\";#xD;\n  src.item first as item where (linkId = 'Ccc.B3.DE06') and answer.exists() then {#xD;\n    item.answer first as a then {#xD;\n      a.value as val -&gt;  tgt.type = create('CodeableConcept') as CC,  CC.text = 'new consultation',  CC.coding = val \"aCccb3de06\";#xD;\n    } \"aCccb3de06\";#xD;\n  } \"58ee7f8b\";#xD;\n}#xD;\n#xD;\ngroup CccobservationCccb3de05(source src, target tgt) {#xD;\n  src -&gt;  tgt.identifier = create('Identifier') as CodeID,  CodeID.system = 'http://hl7.org/fhir/namingsystem-identifier-type',  CodeID.use = 'official',  CodeID.value = 'uuid',  CodeID.id = uuid() \"id-Cccb3de05\";#xD;\n  src.encounter as encounter -&gt; tgt.encounter = encounter \"35bc6b82\";#xD;\n  src.subject as subject -&gt;  tgt.subject = subject,  tgt.meta = create('Meta') as newMeta,  newMeta.profile = 'https://smart.who.int/ccc/StructureDefinition/Cccobservation',  tgt.code = create('CodeableConcept') as concept,  concept.coding = create('Coding') as coding,  coding.system = 'https://smart.who.int/ccc/CodeSystem/Ccc-custom-codes',  coding.code = 'Ccc.B3.DE05' \"code-Cccb3de05\";#xD;\n  src.item as itemtimestamp where linkId = 'timestamp' then {#xD;\n    itemtimestamp.answer first as atimestamp then {#xD;\n      atimestamp.value as val -&gt; tgt.issued = val \"5af77f2c\";#xD;\n    } \"7f22f29f\";#xD;\n  } \"aae7a11d\";#xD;\n  src.subject as subject -&gt; tgt.subject = subject \"patient\";#xD;\n  src.item first as item where (linkId = 'Ccc.B3.DE05') and answer.exists() then {#xD;\n    item.answer first as a then {#xD;\n      a where a.value = true -&gt;  tgt.status = 'final',  tgt.value = true \"final-Cccb3de05\";#xD;\n      a where a.value = false -&gt;  tgt.status = 'cancelled',  tgt.value = false \"notfound-Cccb3de05\";#xD;\n    } \"bdab9370\";#xD;\n  } \"5cf8dcb4\";#xD;\n}#xD;\n#xD;\n</pre></div>"^^rdf:XMLLiteral ]
