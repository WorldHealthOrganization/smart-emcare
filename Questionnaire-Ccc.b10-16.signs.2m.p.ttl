       ]
     ] ) ;
     fhir:linkId [ fhir:v "Ccc.B14S2.DE05" ] ;
     fhir:text [ fhir:v "Has Clouding of the Cornea previously been treated" ] ;
     fhir:type [ fhir:v "boolean" ] ;
     fhir:required [ fhir:v false ] ;
     fhir:repeats [ fhir:v false ]
