       ] ) ;
       fhir:linkId [ fhir:v "Ccc.B15S2.DE01-help" ] ;
       fhir:text [ fhir:v "<span class=\"caps\">LOOK</span> at the skin of the child’s palm. Hold the child’s palm open by grasping it gently from the side. Do not stretch the fingers backwards. This may cause pallor by blocking the blood supply. Compare the colour of the child’s palm with your own palm and with the palms of other children. The child has some palmar pallor if the skin of the child’s palm is pale. The child has severe palmar pallor if the skin of the palm is very pale or so pale that it looks white." ] ;
       fhir:type [ fhir:v "display" ]
     ] )
