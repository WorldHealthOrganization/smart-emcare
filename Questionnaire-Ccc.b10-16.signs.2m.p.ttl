       ]
     ] ) ;
     fhir:linkId [ fhir:v "Ccc.B14S2.DE06" ] ;
     fhir:text [ fhir:v "Generalised or Localised Skin Problem" ] ;
     fhir:type [ fhir:v "choice" ] ;
     fhir:required [ fhir:v true ] ;
     fhir:repeats [ fhir:v true ] ;
     fhir:answerOption ( [
