       fhir:v "http://hl7.org/fhir/StructureDefinition/variable"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/variable>
     ] ;
     fhir:value [
       a fhir:Expression ;
       fhir:name [ fhir:v "AgeInMonths" ] ;
       fhir:language [ fhir:v "text/fhirpath" ] ;
       fhir:expression [ fhir:v "iif(%resource.repeat(item).where(linkId='dob').answer.first().exists(),(today()-%resource.repeat(item).where(linkId='dob').answer.first().value)-(today()-%resource.repeat(item).where(linkId='dob').answer.first().value),{})" ]
     ]
  ] [
