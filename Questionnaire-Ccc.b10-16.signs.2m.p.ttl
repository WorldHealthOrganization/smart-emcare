         ]
       ] ) ;
       fhir:linkId [ fhir:v "Ccc.B22.DE02" ] ;
       fhir:type [ fhir:v "choice" ] ;
       fhir:required [ fhir:v false ] ;
       fhir:repeats [ fhir:v true ] ;
       fhir:answerOption ( [
         fhir:value [
           a fhir:Coding ;
