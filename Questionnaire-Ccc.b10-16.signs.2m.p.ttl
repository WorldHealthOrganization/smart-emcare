       ]
     ] ) ;
     fhir:linkId [ fhir:v "Ccc.B13S2.DE03" ] ;
     fhir:text [ fhir:v "Pus Seen Draining from the Ear for how long?" ] ;
     fhir:type [ fhir:v "choice" ] ;
     fhir:required [ fhir:v true ] ;
