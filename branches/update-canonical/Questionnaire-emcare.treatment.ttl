         a fhir:Expression ;
         fhir:language [ fhir:v "text/fhirpath" ] ;
         fhir:expression [ fhir:v "now()" ]
       ]
     ] [
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/questionnaire-hidden"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/questionnaire-hidden>
       ] ;
       fhir:value [
         a fhir:Boolean ;
         fhir:v true
       ]
     ] ) ;
     fhir:linkId [ fhir:v "timestamp" ] ;
     fhir:type [ fhir:v "dateTime" ] ;
     fhir:required [ fhir:v false ]
  ] ) . # 

