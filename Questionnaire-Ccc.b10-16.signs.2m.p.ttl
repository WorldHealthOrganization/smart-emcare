           ] )
         ]
       ] ) ;
       fhir:linkId [ fhir:v "Ccc.B13S2.DE02-help" ] ;
       fhir:text [ fhir:v "Look inside the child’s ear to see if pus is draining. That is a sign of infection, even if the child is not feeling any pain. Draining pus is a sign of infection" ] ;
       fhir:type [ fhir:v "display" ]
     ] )
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-enableWhenExpression"^^xsd:anyURI ;
